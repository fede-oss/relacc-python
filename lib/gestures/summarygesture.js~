var util         = require("util");
var Point        = require("../geom/point");
var PointSet     = require("../geom/pointset");
var Measure      = require("../geom/measure");
var Gesture      = require("./gesture");
var PtAlignType  = require("./ptaligntype");
var PDollarAlt   = require("./pdollaralt");

// Comparison function for numerical array sorting.
function numericSort(a, b) {
  return a - b;
};

// Compute the points that will be used for the alignment process.
function getPointsForAlignment(gesture) {
  var points = PointSet.clone(gesture.points);
  var center = new Point(); // Note: new Point() ~ PointSet.centroid(points)
  return PointSet.translateBy(points, center);
};

// Compute centroid and medoid gestures.
function computeSummaryShapes(self, gestures, popularStrokeNum) {
  var centroid = []
    , medoid   = []
    , xPoints  = []
    , yPoints  = []
    ;
  var i, g, collectionLen = gestures.length;
  for (i = 0; i < self.refGesture.samplingRate; i++) {
    centroid.push(new Point());
    medoid.push(new Point());
  }
  for (g = 0; g < collectionLen; g++) {
    var gesture = gestures[g];
    var numStrk = PointSet.countStrokes(gesture.points);
    // TODO: Discard "outlier" gestures only for drawing.
    if (popularStrokeNum > 0 && numStrk > popularStrokeNum) continue;
    var points = self.alignGesture(gesture, self.alignmentType);
//    // Discard downsampled gesture samples, if any.
//    if (points.length < self.refGesture.samplingRate) continue;
    for (i = 0; i < self.refGesture.samplingRate; i++) {
      var pt = points[i];
      centroid[i] = pt.add(centroid[i]);
      if (typeof xPoints[i] === 'undefined') {
        xPoints.push([]);
        yPoints.push([]);
      }
      xPoints[i].push(pt.X);
      yPoints[i].push(pt.Y);
    }
  }
  var pivot = Math.floor(collectionLen/2);
  for (i = 0; i < self.refGesture.samplingRate; i++) {
    centroid[i] = centroid[i].divideBy(collectionLen);
    xPoints[i].sort(numericSort);
    yPoints[i].sort(numericSort);
    medoid[i] = new Point( xPoints[i][pivot], yPoints[i][pivot], centroid[i].T, centroid[i].StrokeID );
  }
  return { centroid: centroid, medoid: medoid };
};

/**
 * Compute the summary gesture from a set of gestures,
 * by aligning all gestures with a summary gesture; e.g. centroid, medoid, k-NN.
 * @constructor
 * @param {Array} gestures - Gesture collection.
 * @param {Number} alignmentType - Type of alignment: 1 (chronological, default) or 2 (point cloud).
 * @param {String} summaryShape - Gesture reference shape (aka task axis): centroid, medoid, kcentroid, kmedoid.
 * @param {Boolean} usePopularStrokeNum - If true, select gestures that were executed with the same number of strokes to compute the task axis.
 * @throws {Error} Gesture names cannot be different.
 */
var SummaryGesture = function(gestures, alignmentType, summaryShape, usePopularStrokeNum) {

  var self = this;
  // Inherit from base class Gesture.
  self.prototype = Object.create(Gesture.prototype);
  // Initialize the class with the first gesture in the set, i.e.,
  // the reference to which all the other gesture samples will be aligned.
  var refg = gestures[0];
  // Call parent constructor.
  Gesture.call(self, refg.points, refg.name, refg.samplingRate);

  var collectionLen = gestures.length;
  // Ensure that we get the same gesture labels as input.
  for (var i = 1; i < collectionLen; i++) {
    if (gestures[i].name != refg.name) {
      throw new Error("Gesture names cannot be different.");
    }
  }
  /** Pointer to the base gesture. */
  self.refGesture = refg;
  /** Specify how points are aligned during the averaging process. */
  self.alignmentType = alignmentType || PtAlignType.CHRONOLOGICAL;
  // Check if usePopularStrokeNum is specified.
  var popularStrokeNum = 0;
  if (usePopularStrokeNum) {
    var strokeHist = {};
    for (var g = 0; g < collectionLen; g++) {
      var gesture = gestures[g];
      var numStrk = PointSet.countStrokes(gesture.points);
      if (typeof strokeHist[numStrk] === 'undefined') strokeHist[numStrk] = 0;
      strokeHist[numStrk]++;
    }
    var popularStrokeVal = 0;
    for (var key in strokeHist) {
      var val = strokeHist[key];
      if (val > popularStrokeVal) {
        popularStrokeVal = val;
        popularStrokeNum = parseInt(key, 10);
      }
    }
  }
  // Compute the centroid and median gesture of the input gesture set.
  var shapes = computeSummaryShapes(self, gestures, popularStrokeNum);
  // In Nearest-Neighbor mode, the gesture sample that is closest to the reference shape becomes the representative gesture.
  function knn(referenceGesture) {
    var idx = -1;
    var min = Number.MAX_VALUE;
    for (var g = 0; g < collectionLen; g++) {
      var points = self.alignGesture(gestures[g], alignmentType);
//      // Discard downsampled gesture samples, if any.
//      if (points.length < refg.samplingRate) continue;
      var distance = 0;
      for (var i = 0; i < refg.samplingRate; i++) {
        distance += Measure.sqDistance(referenceGesture[i], points[i]);
      }
      if (distance < min) {
        min = distance;
        idx = g;
      }
    }
    return idx;
  };

  switch (summaryShape) {
    case 'centroid':
      self.originalPoints = shapes.centroid;
      break;
    case 'medoid':
      self.originalPoints = shapes.medoid;
      break;
    case 'kmedoid':
      var closestIndex = knn(shapes.medoid);
      self.originalPoints = gestures[closestIndex].originalPoints;
      break;
    case 'kcentroid':
      var closestIndex = knn(shapes.centroid);
      self.originalPoints = gestures[closestIndex].originalPoints;
      break;
    default:
      break;
  }
  // Note: all gestures have the same sampling rate.
  self.preprocess(self.samplingRate);

};

SummaryGesture.prototype = {

  /**
   * Align a gesture to the centroid.
   * @param {Array} gesture - Gesture points.
   * @param {Number} alignmentType - Type of alignment: 1 (chronological) or 2 (point cloud).
   */
  alignGesture: function(gesture, alignmentType) {
    var points = getPointsForAlignment(gesture);
    if (alignmentType == PtAlignType.CHRONOLOGICAL) return points;

    var alignment = PDollarAlt.match(getPointsForAlignment(this.refGesture), points);
    var newPoints = [];
    for (var i = 0; i < this.refGesture.samplingRate; i++) {
      var pt = points[alignment[i]];
      pt.StrokeID = 0; // Point clouds don't have strokes
      newPoints.push(pt);
    }
    return newPoints;
  },

  /**
   * Return the points of the average gesture.
   */
  getPoints: function() {
    return getPointsForAlignment(this); //getPointsForAlignment(this.refGesture);
  }

};

/**
 * Summary gesture computation.
 * @module lib/geom/summarygesture
 */
module.exports = SummaryGesture;
/**
 * Compute the points that will be used for the alignment process.
 * @static
 * @param {Array} gesture - Gesture points.
 * @return {Array}
 */
module.exports.getPointsForAlignment = getPointsForAlignment;
/**
 * @static
 * @param {SummaryGesture} self - SummaryGesture instance.
 * @param {Array} Gesture collection.
 * @param {Number} popularStrokeNum - Number of strokes.
 * @return {Object} summary - Summary shapes.
 * @return {Array} summary.centroid - Centroid gesture.
 * @return {Array} summary.medoid - Medoid gesture.
 */
module.exports.computeSummaryShapes = computeSummaryShapes;
